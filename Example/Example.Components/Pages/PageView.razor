@page "/components/page-view"
@using Example.Components.Models
@rendermode InteractiveServer
@inherits PageViewBase<TaskViewModel>

<h1>PageViewBase&lt;T&gt;</h1>

<p>
    <code>PageViewBase&lt;T&gt;</code> is a thin wrapper for read-only pages. It owns the
    <code>Model</code>, supplies a <code>LoadAsync</code> hook, exposes <code>IsLoading</code>,
    and (by default) persists the model into <code>PersistentComponentState</code> so the
    transition <em>SSR → InteractiveServer</em> happens without a second load.
</p>

@if (IsLoading || Model is null)
{
    <p class="muted">Loading…</p>
}
else
{
    <section class="card">
        <h2>@Model.Title</h2>
        <dl>
            <dt>Priority</dt>  <dd>@Model.Priority</dd>
            <dt>Due</dt>       <dd>@Model.DueDate</dd>
            <dt>Completed</dt> <dd>@Model.Completed</dd>
        </dl>
        <p>@Model.Notes</p>
    </section>

    <section class="card">
        <button class="btn-primary" @onclick="Reload">Reload</button>
    </section>
}

<section class="card">
    <h2>How it works</h2>
    <pre>@@inherits PageViewBase&lt;TaskViewModel&gt;

protected override async Task&lt;TaskViewModel?&gt; LoadAsync(CancellationToken ct)
{
    // your data layer call
    return await _store.GetCurrentTaskAsync(ct);
}</pre>
</section>

@code {
    // Simulate I/O delay to make IsLoading observable.
    protected override async Task<TaskViewModel?> LoadAsync(CancellationToken cancellationToken)
    {
        await Task.Delay(250, cancellationToken);
        return new TaskViewModel();
    }

    Task Reload() => RefreshAsync();
}
