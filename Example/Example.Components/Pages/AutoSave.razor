@page "/components/auto-save"
@using Example.Components.Models
@rendermode InteractiveServer
@inherits PageEditBase<TaskViewModel>

<h1>[AutoSave] per-field saving</h1>

<p>
    Properties decorated with <code>[AutoSave]</code> (optionally <code>[AutoSave(DelayMs=…)]</code>)
    trigger <code>AutoSaveAsync(fieldName, oldValue, newValue, ct)</code> after a debounce
    interval. The override below pushes a toast — a real app would <code>PATCH</code> the
    field to its backend.
</p>

<EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmit" FormName="autosave">
    <DataAnnotationsValidator />

    <section class="card stack">
        <label>
            Title <small class="muted">(no auto-save)</small>
            <InputText @bind-Value="Model.Title" />
        </label>

        <label>
            Notes <small class="muted">[AutoSave(1500ms)]</small>
            <InputTextArea @bind-Value="Model.Notes" rows="3" />
        </label>

        <label>
            Priority <small class="muted">[AutoSave]</small>
            <InputNumber @bind-Value="Model.Priority" />
        </label>

        <button type="submit" class="btn-primary">Submit anyway</button>
    </section>
</EditForm>

<section class="card">
    <h2>Auto-save log</h2>
    @if (_log.Count == 0)
    {
        <p class="muted">Edit "Notes" or "Priority" and pause typing — entries appear here.</p>
    }
    else
    {
        <ul class="log">
            @foreach (var entry in _log)
            {
                <li><code>@entry</code></li>
            }
        </ul>
    }
</section>

@code {
    private readonly List<string> _log = [];

    protected override Task AutoSaveAsync(string fieldName, object? oldValue, object? newValue, CancellationToken cancellationToken)
    {
        _log.Insert(0, $"{DateTime.Now:HH:mm:ss.fff}  {fieldName}: {oldValue ?? "∅"} → {newValue ?? "∅"}");
        if (_log.Count > 10) _log.RemoveRange(10, _log.Count - 10);
        Toast.AddInfo("Auto-saved {0}", fieldName);
        return InvokeAsync(StateHasChanged);
    }

    protected override Task SubmitAsync(CancellationToken cancellationToken)
    {
        Toast.AddSuccess("Submitted form");
        return Task.CompletedTask;
    }
}
