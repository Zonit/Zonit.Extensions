@page "/components/auto-save"
@using Example.Components.Models
@rendermode InteractiveServer
@inherits PageEditBase<TaskViewModel>

<h1>[AutoSave] per-field saving</h1>

<p>
    Properties decorated with <code>[AutoSave]</code> (optionally <code>[AutoSave(DelayMs=…)]</code>)
    trigger <code>AutoSaveAsync(fieldName, oldValue, newValue, ct)</code> after a debounce
    interval. The override below pushes a toast — a real app would <code>PATCH</code> the
    field to its backend.
</p>

<EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmit" FormName="autosave">
    <DataAnnotationsValidator />

    @*
        Default <InputText> / <InputTextArea> notify EditContext on `onchange` (blur),
        so the AutoSave debounce only starts once the user leaves the field. For a
        true "save while typing" experience the inputs must notify on EVERY keystroke.
        We bypass InputBase here and wire `oninput` -> Model + EditContext.NotifyFieldChanged
        manually. The framework's HandleFieldAutoSave then ticks its 1500 ms timer on
        every change and we land at the desired UX without changing PageEditBase.
    *@
    <section class="card stack">
        <label>
            Title <small class="muted">(no auto-save)</small>
            <input value="@Model.Title"
                   @oninput="e => OnFieldInput(nameof(Model.Title), e.Value?.ToString())" />
        </label>

        <label>
            Notes <small class="muted">[AutoSave(1500ms)]</small>
            <textarea rows="3"
                      value="@Model.Notes"
                      @oninput="e => OnFieldInput(nameof(Model.Notes), e.Value?.ToString())"></textarea>
        </label>

        <label>
            Priority <small class="muted">[AutoSave]</small>
            <input type="number"
                   value="@Model.Priority"
                   @oninput="e => OnPriorityInput(e.Value?.ToString())" />
        </label>

        <button type="submit" class="btn-primary">Submit anyway</button>
    </section>
</EditForm>

<section class="card">
    <h2>Auto-save log</h2>
    @if (_log.Count == 0)
    {
        <p class="muted">Edit "Notes" or "Priority" and pause typing — entries appear here.</p>
    }
    else
    {
        <ul class="log">
            @foreach (var entry in _log)
            {
                <li><code>@entry</code></li>
            }
        </ul>
    }
</section>

@code {
    private readonly List<string> _log = [];

    void OnFieldInput(string fieldName, string? value)
    {
        switch (fieldName)
        {
            case nameof(TaskViewModel.Title): Model.Title = value ?? string.Empty; break;
            case nameof(TaskViewModel.Notes): Model.Notes = value ?? string.Empty; break;
        }

        // Tell EditContext the field changed so AutoSave timers re-arm.
        EditContext?.NotifyFieldChanged(new FieldIdentifier(Model, fieldName));
    }

    void OnPriorityInput(string? raw)
    {
        if (int.TryParse(raw, out var v))
            Model.Priority = v;

        EditContext?.NotifyFieldChanged(new FieldIdentifier(Model, nameof(TaskViewModel.Priority)));
    }

    protected override Task AutoSaveAsync(string fieldName, object? oldValue, object? newValue, CancellationToken cancellationToken)
    {
        _log.Insert(0, $"{DateTime.Now:HH:mm:ss.fff}  {fieldName}: {oldValue ?? "∅"} → {newValue ?? "∅"}");
        if (_log.Count > 10) _log.RemoveRange(10, _log.Count - 10);
        Toast.AddInfo("Auto-saved {0}", fieldName);
        return InvokeAsync(StateHasChanged);
    }

    protected override Task SubmitAsync(CancellationToken cancellationToken)
    {
        Toast.AddSuccess("Submitted form");
        return Task.CompletedTask;
    }
}
