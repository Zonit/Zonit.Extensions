@page "/components/page-edit"
@using Example.Components.Models
@rendermode InteractiveServer
@inherits PageEditBase<TaskViewModel>

<h1>PageEditBase&lt;T&gt;</h1>

<p>
    Form base class with: <code>EditContext</code> + <code>DataAnnotations</code> validation,
    <code>HasChanges</code> tracking, automatic string trim &amp; whitespace normalisation
    on submit, duplicate-submit guard, translated validation messages, and
    <code>[AutoSave]</code> per-field auto-save (see <a href="/components/auto-save">next page</a>).
</p>

<EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit" FormName="task-edit">
    <DataAnnotationsValidator />

    <section class="card stack">
        <label>
            Title
            <InputText @bind-Value="Model.Title" />
            <ValidationMessage For="@(() => Model.Title)" />
        </label>

        <label>
            Notes
            <InputTextArea @bind-Value="Model.Notes" rows="3" />
            <ValidationMessage For="@(() => Model.Notes)" />
        </label>

        <label>
            Priority (1–5)
            <InputNumber @bind-Value="Model.Priority" />
            <ValidationMessage For="@(() => Model.Priority)" />
        </label>

        <label>
            Due date
            <InputDate @bind-Value="Model.DueDate" />
        </label>

        <label class="checkbox">
            <InputCheckbox @bind-Value="Model.Completed" /> Completed
        </label>

        <div class="actions">
            <button type="submit" class="btn-primary" disabled="@(!HasChanges || Processing)">
                @(Processing ? "Saving…" : "Save")
            </button>
            <button type="button" @onclick="Reset" disabled="@(!HasChanges || Processing)">Reset</button>
            <span class="muted">HasChanges: @HasChanges · IsValid: @IsValid</span>
        </div>
    </section>
</EditForm>

<section class="card">
    <h2>What happens on submit</h2>
    <ol>
        <li><code>DataAnnotations.Validator.TryValidateObject</code> runs (translated messages).</li>
        <li>If <code>AutoTrimStrings</code> / <code>AutoNormalizeWhitespace</code> are on (defaults: <em>true</em>),
            <code>CleanModelData()</code> runs <em>before</em> <code>SubmitAsync</code>.</li>
        <li><code>SubmitAsync(CancellationToken)</code> is invoked — your save call goes here.</li>
        <li><code>Toast.AddSuccess(...)</code> + <code>HasChanges</code> reset to <em>false</em>.</li>
    </ol>
</section>

@code {
    protected override async Task SubmitAsync(CancellationToken cancellationToken)
    {
        await Task.Delay(400, cancellationToken);   // pretend to call a backend
        Toast.AddSuccess("Saved \"{0}\"", Model.Title);
    }

    void Reset() => ResetModel();
}
