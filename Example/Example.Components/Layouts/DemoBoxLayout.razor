@*
    Demo "box" layout — narrow centered card with no header / footer / nav. The kind of
    chrome a plug-in's login or error page would request via [LayoutKey("Demo.Box")].
    The plug-in doesn't reference this class, only the string key.
*@
@inherits LayoutComponentBase
@namespace Example.Layouts

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--surface, #f3f4f6);">
    <div style="max-width: 520px; width: 100%; padding: 32px; background: white; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.08);">
        <div style="margin-bottom: 16px; font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">
            Demo.Box layout (Example assembly)
        </div>
        @Body
    </div>
</div>
