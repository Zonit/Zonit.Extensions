@page "/auth/authorize-view"
@rendermode InteractiveServer

<h1>&lt;AuthorizeView&gt;</h1>

<p>
    Standard Blazor authorization component. The <code>Roles</code> attribute does role
    checks; <code>Policy</code> resolves through <code>IAuthorizationPolicyProvider</code> —
    Zonit's <code>PermissionPolicyProvider</code> synthesises a policy on the fly when the
    name parses as a <code>Permission</code> token (no <code>AddPolicy(...)</code> needed).
</p>

<section class="card">
    <h2>By role</h2>
    <AuthorizeView Roles="admin">
        <Authorized><div class="badge ok">Visible to administrators</div></Authorized>
        <NotAuthorized><div class="badge muted">Hidden from non-admins</div></NotAuthorized>
    </AuthorizeView>
    <pre>&lt;AuthorizeView Roles="admin"&gt;...&lt;/AuthorizeView&gt;</pre>
</section>

<section class="card">
    <h2>By concrete permission</h2>
    <AuthorizeView Policy="users.read">
        <Authorized><div class="badge ok">You hold <code>users.read</code></div></Authorized>
        <NotAuthorized><div class="badge muted">No <code>users.read</code> permission</div></NotAuthorized>
    </AuthorizeView>
    <pre>&lt;AuthorizeView Policy="users.read"&gt;...&lt;/AuthorizeView&gt;</pre>
</section>

<section class="card">
    <h2>By wildcard permission</h2>
    <p>
        The admin user holds <code>*</code> which implies <em>everything</em>. The standard
        user holds only <code>users.read</code> — they are denied below.
    </p>
    <AuthorizeView Policy="settings.write">
        <Authorized><div class="badge ok">You hold <code>settings.write</code> (or a wildcard)</div></Authorized>
        <NotAuthorized><div class="badge muted">No <code>settings.write</code></div></NotAuthorized>
    </AuthorizeView>
    <pre>&lt;AuthorizeView Policy="settings.write"&gt;...&lt;/AuthorizeView&gt;</pre>
</section>

<section class="card">
    <h2>Authorization context</h2>
    <p>You can inspect the current principal directly:</p>
    <AuthorizeView>
        <Authorized Context="auth">
            <pre>auth.User.Identity?.Name        -> @auth.User.Identity?.Name
auth.User.IsInRole("user")      -> @auth.User.IsInRole("user")
Claims:
  @foreach (var c in auth.User.Claims) {
@($"  {c.Type} = {c.Value}\n")
  }</pre>
        </Authorized>
        <NotAuthorized>
            <p>Anonymous.</p>
        </NotAuthorized>
    </AuthorizeView>
</section>
