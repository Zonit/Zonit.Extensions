@page "/auth"
@rendermode InteractiveServer
@inherits PageBase

<h1>Identity</h1>

<p>
    <code>IAuthenticatedProvider.Current</code> returns the lightweight
    <code>Identity</code> value object — Id, Name, Roles, Permissions — hydrated by
    <code>SessionMiddleware</code> from the auth cookie. <strong>No second DB call per request.</strong>
</p>

@if (!Authenticated.Current.HasValue)
{
    <div class="alert">You are anonymous. <a href="/login">Log in</a> to populate this page.</div>
}
else
{
    var id = Authenticated.Current;
    <section class="card">
        <h2>Current</h2>
        <dl>
            <dt>Id</dt>          <dd><code>@id.Id</code></dd>
            <dt>Name</dt>        <dd>@id.Name.Value</dd>
            <dt>Has snapshot</dt><dd>@id.HasSnapshot</dd>
            <dt>Roles</dt>       <dd>@string.Join(", ", id.Roles.Select(r => r.Value))</dd>
            <dt>Permissions</dt> <dd>@string.Join(", ", id.Permissions.Select(p => p.Value))</dd>
        </dl>
    </section>

    <section class="card">
        <h2>Behavioural checks</h2>
        <pre>id.IsInRole("admin")              -> @id.IsInRole(Role.TryCreate("admin", out var r1) ? r1 : Role.Empty)
id.HasPermission("users.read")    -> @id.HasPermission(Permission.TryCreate("users.read", out var p1) ? p1 : Permission.Empty)
id.HasPermission("settings.write") -> @id.HasPermission(Permission.TryCreate("settings.write", out var p2) ? p2 : Permission.Empty)</pre>
        <p class="muted">
            Wildcards are honoured: <code>*</code> on the admin user satisfies any concrete
            permission via <code>Permission.Implies</code>.
        </p>
    </section>
}

<section class="card">
    <h2>Cascading <code>AuthenticationState</code></h2>
    <p>The same identity is also exposed through Blazor's
       <code>CascadingAuthenticationState</code>, populated by
       <code>SessionAuthenticationService</code>. That's what makes
       <code>&lt;AuthorizeView&gt;</code> work without further plumbing — see the next page.</p>
</section>
