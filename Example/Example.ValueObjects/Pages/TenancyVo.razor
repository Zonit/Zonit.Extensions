@page "/vo/tenancy"
@using TimeZone = Zonit.Extensions.TimeZone
@inject IWorkspaceProvider Workspace
@inject ICatalogProvider Catalog

<h1>Tenancy value objects</h1>

<p>
    <code>Organization</code> and <code>Project</code> follow the same pattern as
    <code>Identity</code>: <code>readonly struct</code> with Id + lightweight snapshot,
    implicit <code>Guid ↔ VO</code>, equality by Id, hand-rolled JSON / TypeConverter.
</p>

<section class="card">
    <h2>Composite VO recipe</h2>
    <pre>public sealed class Order
{
    public Identity     Author       { get; init; }
    public Organization Organization { get; init; }   // FK as VO
    public Project      Project      { get; init; }
    public Money        Total        { get; init; }
}</pre>
    <p class="muted">
        EF column type: <code>Guid</code> (via the implicit operator). Zonit.Extensions.Databases hydrates
        snapshots on demand: <code>repo.Extension(x =&gt; x.Author).GetAsync()</code>.
    </p>
</section>

<section class="card">
    <h2>Current scope</h2>
    <dl>
        <dt>Organization</dt>
        <dd>@(Workspace.Organization.HasValue ? Workspace.Organization.Name.Value + " (" + Workspace.Organization.Id + ")" : "(none)")</dd>
        <dt>Project</dt>
        <dd>@(Catalog.Project.HasValue ? Catalog.Project.Name.Value + " (" + Catalog.Project.Id + ")" : "(none)")</dd>
    </dl>
</section>

<section class="card">
    <h2>Culture / TimeZone</h2>
    @{
        Culture pl = "pl-PL";
        TimeZone warsaw = "Europe/Warsaw";
        TimeZone fixedOffset = 2;
    }
    <pre>Culture pl       = "pl-PL";        -> @pl.Value
TimeZone warsaw  = "Europe/Warsaw"; -> @warsaw.Value (offset @warsaw.Offset)
TimeZone fixed+2 = 2;               -> @fixedOffset.Value (fixed: @fixedOffset.IsFixedOffset)
warsaw.ConvertFromUtc(DateTime.UtcNow) -> @warsaw.ConvertFromUtc(DateTime.UtcNow).ToString("u")</pre>
</section>
