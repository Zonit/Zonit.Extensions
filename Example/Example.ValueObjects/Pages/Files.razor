@page "/vo/files"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms

<h1>File-shaped value objects</h1>

<p>
    <code>Asset</code> is the headline file VO: pick a file, get an immutable snapshot
    that already knows its bytes, MIME type (validated against magic bytes — not just
    the extension), SHA-256, signature, and pretty-printed size. <code>FileSize</code>
    and <code>Color</code> are tiny helpers reused all over the codebase.
</p>

<section class="card">
    <h2>Asset — drop a file</h2>
    <InputFile OnChange="OnFile" />

    @if (_asset.HasValue)
    {
        <pre>asset.OriginalName  -> @_asset.OriginalName.Value
asset.UniqueName    -> @_asset.UniqueName
asset.Extension     -> @_asset.Extension
asset.MediaType     -> @_asset.MediaType.Value
asset.Signature     -> @_asset.Signature
asset.Size          -> @_asset.Size
asset.Sha256        -> @_asset.Sha256
asset.CreatedAt     -> @_asset.CreatedAt:O</pre>

        @if (_asset.MediaType.Value.StartsWith("image/"))
        {
            <p class="muted">Preview (rendered straight from <code>Asset.DataUrl</code>):</p>
            <img src="@_asset.DataUrl" alt="@_asset.OriginalName.Value" style="max-width:240px;border:1px solid var(--neutral)" />
        }
    }
    else if (_error is not null)
    {
        <p class="muted">@_error</p>
    }
</section>

<section class="card">
    <h2>FileSize — pretty-print</h2>
    <pre>FileSize.OneKilobyte         -> @FileSize.OneKilobyte
FileSize.OneMegabyte         -> @FileSize.OneMegabyte
FileSize.OneGigabyte         -> @FileSize.OneGigabyte
FileSize.HundredMegabytes    -> @FileSize.HundredMegabytes
new FileSize(15_000_000_000) -> @(new FileSize(15_000_000_000))</pre>

    <p class="muted">Bytes round-trip through <code>FileSize.TryParse("1.5 GB", null, out var f)</code>:</p>
    @{ FileSize.TryParse(_sizeInput, null, out var parsed); }
    <input class="input" @bind="_sizeInput" @bind:event="oninput" />
    <pre>FileSize.TryParse("@_sizeInput") -> @(parsed.Bytes > 0 ? parsed.ToString() : "(invalid)")</pre>
</section>

<section class="card">
    <h2>Color — hex, RGB, OKLCH roundtrip</h2>
    <input type="color" class="input" @bind="_color" @bind:event="oninput" />
    @{ Color.TryParse(_color, null, out var c); }
    <pre>Color.TryParse("@_color") ->
    Hex   = @c.Hex
    OKLCH = L=@c.L.ToString("0.00") C=@c.C.ToString("0.00") H=@c.H.ToString("0.0")
    Alpha = @c.Alpha</pre>
</section>

@code {
    Asset _asset = Asset.Empty;
    string? _error;
    string _sizeInput = "1.5 GB";
    string _color = "#2563EB";

    async Task OnFile(InputFileChangeEventArgs e)
    {
        _error = null;
        try
        {
            var file = e.File;

            // Cap at 10 MB so a misclick doesn't try to slurp a multi-gig blob into memory.
            // The backing Asset.MaxSize is 100 MB — this is a UI-side guard for the demo only.
            await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            _asset = new Asset(ms.ToArray(), file.Name);
        }
        catch (Exception ex)
        {
            _asset = Asset.Empty;
            _error = $"Could not load file: {ex.Message}";
        }
    }
}
