@page "/vo/identity"
@inject IAuthenticatedProvider Auth

<h1>Identity / Role / Permission</h1>

<p>
    The <code>Identity</code> VO carries Id + Name + Roles + Permissions. Roles and
    permissions are tiny VOs validated on construction; permissions support wildcards via
    <code>Permission.Implies</code>.
</p>

<section class="card">
    <h2>Construction</h2>
    <pre>// Id-only — typical for foreign-key columns
Identity id = Guid.NewGuid();          // implicit

// Full snapshot
var hydrated = new Identity(
    Guid.NewGuid(),
    "Linus Pauling",
    roles:       new[] { Role.Create("admin") },
    permissions: new[] { Permission.Create("orders.*") });</pre>
</section>

<section class="card">
    <h2>Wildcards: <code>Permission.Implies</code></h2>
    <p>
        Tokens are dot-separated; <code>*</code> matches everything below a segment.
        <code>Implies(other)</code> returns <em>true</em> when the holder satisfies <em>other</em>.
    </p>
    @{
        Permission.TryCreate("orders.*", out var granted);
        Permission.TryCreate("orders.read", out var requested);
        Permission.TryCreate("invoices.read", out var unrelated);
    }
    <pre>granted = "orders.*"
granted.Implies("orders.read")   -> @granted.Implies(requested)
granted.Implies("invoices.read") -> @granted.Implies(unrelated)</pre>
</section>

<section class="card">
    <h2>Current identity</h2>
    @if (!Auth.Current.HasValue)
    {
        <p class="muted">Anonymous — log in to populate.</p>
    }
    else
    {
        <pre>Auth.Current.Id                 -> @Auth.Current.Id
Auth.Current.Name.Value         -> @Auth.Current.Name.Value
Auth.Current.IsInRole("admin")  -> @Auth.Current.IsInRole(Role.TryCreate("admin", out var r) ? r : Role.Empty)
Auth.Current.HasPermission("orders.read")
                                -> @Auth.Current.HasPermission(Permission.TryCreate("orders.read", out var p) ? p : Permission.Empty)</pre>
    }
</section>
