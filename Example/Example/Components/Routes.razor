@*
    Single Router serving the host's pages plus pages from every area assembly.
    AdditionalAssemblies are wired in Program.cs at MapRazorComponents level; we
    re-list them here so client-side routing resolves cross-assembly @page declarations.
*@
<Router AppAssembly="@typeof(Program).Assembly"
        AdditionalAssemblies="@(new[]
        {
            typeof(CulturesArea).Assembly,
            typeof(AuthArea).Assembly,
            typeof(OrganizationsArea).Assembly,
            typeof(ProjectsArea).Assembly,
            typeof(TenantsArea).Assembly,
            typeof(ComponentsArea).Assembly,
            typeof(ValueObjectsArea).Assembly,
            typeof(MudBlazorArea).Assembly,
        })">
    <Found Context="routeData">
        @* ZonitRouteView — drop-in replacement that honours [LayoutKey("...")] /
           [NoLayout] / runtime ILayoutContext alongside Blazor's standard [Layout]. *@
        <Zonit.Extensions.Website.Layouts.Components.ZonitRouteView
            RouteData="@routeData"
            DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                <h1>403 — not authorized</h1>
                <p>You need additional roles or permissions for this page.</p>
                <p><a href="/login">Log in as a different user</a></p>
            </NotAuthorized>
        </Zonit.Extensions.Website.Layouts.Components.ZonitRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>
