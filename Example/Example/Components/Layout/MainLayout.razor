@inherits LayoutComponentBase
@inject ITenantProvider Tenant
@inject ICultureProvider Culture
@inject ICultureManager CultureManager
@inject IAuthenticatedProvider Auth
@implements IDisposable

@*
    Layout: tenant-branded header, area-driven sidebar, top-bar with culture switcher
    and a slot for routed pages. Subscribed to OnChange events from Culture / Tenant /
    Auth so any change re-renders the chrome (e.g. login/logout, language switch).
*@
<div class="app-shell">
    <aside class="sidebar">
        <header class="brand">
            <strong>@Tenant.Settings.Site.Title</strong>
            @if (Tenant.Current?.IsSolo == true)
            {
                <small class="badge solo">solo</small>
            }
            else
            {
                <small class="badge multi">@Tenant.Current?.Domain</small>
            }
        </header>

        <NavMenu />

        <footer class="auth-card">
            @if (Auth.Current.HasValue)
            {
                <div>
                    <strong>@Auth.Current.Name.Value</strong>
                    <div class="muted">@string.Join(", ", Auth.Current.Roles.Select(r => r.Value))</div>
                </div>
                <form action="/auth/logout" method="post" class="inline-form">
                    <button type="submit">Log out</button>
                </form>
            }
            else
            {
                <a class="btn-primary" href="/login">Log in</a>
            }
        </footer>
    </aside>

    <main class="content">
        <header class="topbar">
            <label>
                <span class="muted">Culture:</span>
                <select @onchange="OnCultureChanged" value="@Culture.Current.Value">
                    @foreach (var lang in CultureManager.Supported)
                    {
                        <option value="@lang.Code">@lang.NativeName (@lang.Code)</option>
                    }
                </select>
            </label>
            <span class="muted">
                Date: @DateTime.UtcNow.ToString(Culture.Current.ToCultureInfoOrDefault().DateTimeFormat.ShortDatePattern)
            </span>
            <span class="muted">
                Zone: @CultureManager.TimeZone.Value
            </span>
        </header>

        <article class="page">
            @Body
        </article>
    </main>
</div>

@*
    Toast host. The provider (IToastProvider) is scoped per circuit so a single
    ZonitToasts instance in the layout renders every toast pushed from any page.
    Without this host the calls succeed silently — they end up in the queue but
    nothing in the DOM subscribes.
*@
<ZonitToasts />

@code {
    protected override void OnInitialized() => Culture.OnChange += StateHasChanged;
    public void Dispose() => Culture.OnChange -= StateHasChanged;

    private void OnCultureChanged(ChangeEventArgs e)
    {
        if (e.Value is string code)
            CultureManager.SetCulture(code);
    }
}
