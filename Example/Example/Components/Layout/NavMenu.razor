@inject INavigationProvider Navigation
@inject IAuthenticatedProvider Auth
@implements IDisposable

@*
    Pulls navigation contributed by every IWebsiteArea (each Example.* sub-project
    declares its own NavGroup inside {Domain}Area.cs). The provider performs
    permission filtering automatically — links the current user can't reach are
    dropped before render.
*@
<nav class="nav-menu">
    @foreach (var areaKey in Areas)
    {
        var groups = Navigation.Get(areaKey);
        if (groups.Count == 0) continue;

        foreach (var group in groups)
        {
            <h3>@group.Title.Value</h3>
            @if (group.Children is { Count: > 0 } children)
            {
                <ul>
                    @foreach (var link in children)
                    {
                        if (!IsAllowed(link)) continue;
                        <li>
                            <NavLink href="@link.Url.Value" Match="@(link.Match ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                                @link.Title.Value
                            </NavLink>
                        </li>
                    }
                </ul>
            }
        }
    }
</nav>

@code {
    // Order matters — drives the visual sequence of sections in the sidebar.
    private static readonly string[] Areas = new[]
    {
        "home",
        "cultures",
        "auth",
        "organizations",
        "projects",
        "tenants",
        "components",
        "value-objects",
    };

    protected override void OnInitialized() => Navigation.OnChanged += OnNavChanged;
    public void Dispose() => Navigation.OnChanged -= OnNavChanged;

    private void OnNavChanged(string? _) => InvokeAsync(StateHasChanged);

    // Honour the link-level permission when present. Wildcards are evaluated by
    // Identity.HasPermission via Permission.Implies, so "orders.*" satisfies "orders.read".
    private bool IsAllowed(NavItem link)
    {
        if (!link.Permission.HasValue) return true;
        return Auth.Current.HasValue && Auth.Current.HasPermission(link.Permission);
    }
}
