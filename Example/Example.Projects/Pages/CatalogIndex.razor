@page "/projects"
@rendermode InteractiveServer
@inherits PageBase

<h1>Catalog</h1>

<p>
    <code>ICatalogProvider</code> exposes the current project as a <code>Project</code>
    value object. Hydrated by <code>ProjectMiddleware</code> from
    <code>IProjectSource</code>; scoped to the active organization, so an
    org switch invalidates the project automatically.
</p>

@if (!Catalog.Project.HasValue)
{
    <div class="alert">No project selected.</div>
}
else
{
    <section class="card">
        <h2>Current</h2>
        <dl>
            <dt>Id</dt>   <dd><code>@Catalog.Project.Id</code></dd>
            <dt>Name</dt> <dd>@Catalog.Project.Name.Value</dd>
            <dt>Slug</dt> <dd>@Catalog.Project.Slug.Value</dd>
        </dl>
    </section>
}
